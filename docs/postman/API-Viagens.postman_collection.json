{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "API Viagens Corporativas",
		"description": "Collection para testes da API de Viagens Corporativas Laravel.\n\n## Configuração\n\n1. Importe esta collection no Postman\n2. Configure a variável `base_url` (padrão: `http://localhost:8000/api`)\n3. Execute o request **Login** para salvar o token automaticamente\n4. Todos os requests autenticados usarão o token salvo via `{{token}}`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Endpoints de autenticação JWT (registro, login, logout, refresh e dados do usuário).",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"João Silva\",\n    \"email\": \"joao@example.com\",\n    \"password\": \"senha1234\",\n    \"password_confirmation\": \"senha1234\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Registra um novo usuário e retorna o token JWT.\n\n**Campos obrigatórios:**\n- `name` (string, máx. 255)\n- `email` (string, email válido, único)\n- `password` (string, mín. 8 caracteres)\n- `password_confirmation` (string, deve ser igual ao password)"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.authorization.token);",
									"    pm.test('Token salvo automaticamente', function () {",
									"        pm.expect(jsonData.authorization.token).to.be.a('string');",
									"    });",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"joao@example.com\",\n    \"password\": \"senha1234\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Autentica o usuário e retorna o token JWT.\n\nO token é salvo automaticamente na variável `{{token}}` via script de teste.\n\n**Campos obrigatórios:**\n- `email` (string, email válido)\n- `password` (string)"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.authorization.token);",
									"    pm.test('Token salvo automaticamente', function () {",
									"        pm.expect(jsonData.authorization.token).to.be.a('string');",
									"    });",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "Me",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": ["{{base_url}}"],
							"path": ["auth", "me"]
						},
						"description": "Retorna os dados do usuário autenticado.\n\nRequer token JWT válido no header Authorization."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": ["{{base_url}}"],
							"path": ["auth", "refresh"]
						},
						"description": "Gera um novo token JWT a partir do token atual.\n\nO novo token é salvo automaticamente na variável `{{token}}`."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.authorization.token);",
									"    pm.test('Token atualizado automaticamente', function () {",
									"        pm.expect(jsonData.authorization.token).to.be.a('string');",
									"    });",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout"]
						},
						"description": "Invalida o token JWT atual (logout).\n\nRequer token JWT válido no header Authorization."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.collectionVariables.set('token', '');",
									"    pm.test('Token limpo após logout', function () {",
									"        pm.expect(pm.collectionVariables.get('token')).to.equal('');",
									"    });",
									"}"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Travel Orders",
			"description": "Endpoints de gerenciamento de pedidos de viagem (CRUD + atualização de status).",
			"item": [
