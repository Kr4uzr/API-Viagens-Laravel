							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"destination\": \"Lisboa, Portugal\",\n    \"departure_date\": \"2026-05-10\",\n    \"return_date\": \"2026-05-25\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/travel-orders/1",
							"host": ["{{base_url}}"],
							"path": ["travel-orders", "1"]
						},
						"description": "Atualiza os detalhes (destino e datas) de um pedido de viagem.\n\n**Regras:**\n- Apenas o solicitante (dono do pedido) pode editar (403 se for outro usuário)\n- Apenas pedidos com status `requested` podem ser editados (409 se já aprovado ou cancelado)\n\n**Campos obrigatórios:**\n- `destination` (string, máx. 255)\n- `departure_date` (date, hoje ou futura)\n- `return_date` (date, igual ou posterior à departure_date)"
					},
					"response": []
				},
